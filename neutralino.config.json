{
  "applicationId": "io.github.sstools_jp.rc",
  "version": "0.5.1",
  "defaultMode": "window",
  "documentRoot": "/dist/",
  "url": "/",
  "enableServer": true,
  "nativeAllowList": ["app.*", "os.*", "window.*"],
  "logging": {
    "enabled": true,
    "writeToLogFile": false
  },
  "modes": {
    "window": {
      "title": "RC断面計算",
      "width": 1000,
      "height": 800,
      "minWidth": 540,
      "minHeight": 200,
      "injectClientLibrary": true
    }
  },
  "cli": {
    "binaryName": "rc",
    "resourcesPath": "/dist/",
    "extensionsPath": "/extensions/",
    "binaryVersion": "6.7.0",
    "clientVersion": "6.7.0"
  }
}
